# Application
PORT=3000
NODE_ENV=development
APP_NAME=NestJS API Scaffold
APP_SLUG=nestjs-api-scaffold
APP_DESCRIPTION=NestJS API Scaffold with Fastify, PostgreSQL, Redis, and feature-first modules

# CORS
CORS_ORIGIN=*

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=api
DB_USER=api
DB_PASSWORD=api123
DB_SSL=false

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Cache Configuration
CACHE_TTL=300
CACHE_MAX_ITEMS=100

# Session Configuration
SESSION_SECRET=your-super-secret-key-change-in-production
SESSION_MAX_AGE=604800
SESSION_COOKIE_NAME=nestjs-api-scaffold.sid
WEBSOCKET_PATH=/socket.io

# Email Configuration (SMTP)
EMAIL_ENABLED=true
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@api.com
APP_URL=http://localhost:3000
API_URL=http://localhost:3000

# Google Auth
GOOGLE_AUTH_ENABLED=false
GOOGLE_CLIENT_ID=

# Seed Configuration
# Change these values before running seeds in shared environments
SEED_ADMIN_EMAIL=admin@teste.email
SEED_ADMIN_NAME=Administrador
SEED_ADMIN_PASSWORD=admin123456
SEED_ORGANIZATION_NAME=
